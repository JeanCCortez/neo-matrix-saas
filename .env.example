# NEO MATRIX SaaS - Environment Variables
# Copy to .env and fill in production values

# REQUIRED - Application will fail to start without these
SECRET_KEY=your-32-byte-hex-secret-key-here
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/neo_matrix

# IBM Quantum
IBM_QUANTUM_API_URL=https://api.quantum-computing.ibm.com

# LGPD/GDPR Compliance
DPO_EMAIL=dpo@yourdomain.com

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional
NEO_SEED=
